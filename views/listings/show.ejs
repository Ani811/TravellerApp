<% layout("/layouts/boilerplate") %>

<link rel="stylesheet" href="/css/listing-show.css">
    <div class="listing-hero">
        <article class="listing-card">
            <div class="listing-banner">
                <div class="photo-grid">
                    <div class="main-photo">
                        <img src="<%= listing.image.url %>" class="listing-image" alt="listing_image" id="mainPhoto" />
                        <button type="button" class="show-all">Show all photos</button>
                    </div>
                    <div class="thumbs-grid">
                        <% 
                            let thumbs = [];
                            if (listing.images && listing.images.length) {
                                thumbs = listing.images.slice(0,4).map(i => i.url);
                            } else {
                                for (let i=0;i<4;i++) thumbs.push(listing.image.url);
                            }
                        %>
                        <% thumbs.forEach(function(t, idx){
                            let thumbUrl = (t && t.includes('/upload')) ? t.replace('/upload','/upload/c_fill,h_160,w_220') : t;
                        %>
                            <button type="button" class="thumb-btn" data-src="<%= t %>">
                                <img src="<%= thumbUrl %>" class="thumb-img" alt="thumb<%= idx %>" />
                            </button>
                        <% }) %>
                    </div>
                    <div class="offer-badge">
                        <% if (listing.offer && listing.offer > 0) { %>
                            <%= listing.offer %>% OFF
                        <% } else { %>
                            No Offer
                        <% } %>
                    </div>
                </div>
            </div>
            <div class="listing-body">
                <h1 class="listing-title"><%= listing.title %></h1>
                <p class="listing-subtitle">Owned by <strong><%= listing.owner.username %></strong></p>
                <p class="listing-description"><%= listing.description %></p>

                <div class="listing-meta">
                    <div class="meta-item">
                        <strong>Per day</strong>
                        ₹ <%= listing.price %>
                    </div>
                    <div class="meta-item">
                        <strong>Duration</strong>
                        <%= listing.duration %> days
                    </div>
                    <div class="meta-item">
                        <strong>Location</strong>
                        <%= listing.location %>
                    </div>
                    <div class="meta-item">
                        <strong>Country</strong>
                        <%= listing.country %>
                    </div>
                </div>

                <div class="booking-panel">
                    <h5>Book your stay</h5>
                    <div class="duration-controls">
                        <button id="decreaseDuration" class="btn-secondary-custom" type="button">-</button>
                        <input id="durationInput" type="number" min="1" value="<%= listing.duration %>" />
                        <button id="increaseDuration" class="btn-secondary-custom" type="button">+</button>
                    </div>
                    <div class="booking-total">
                        <div class="total-row"><span>Original total</span><strong>₹ <span id="originalTotal"></span></strong></div>
                        <div class="total-row"><span>Offer</span><strong><span id="offerPercent"><%= listing.offer || 0 %></span>%</strong></div>
                        <div class="total-row"><span>Total after offer</span><strong>₹ <span id="discountedTotal"></span></strong></div>
                    </div>
                    <button id="bookButton" type="button" class="btn-primary-custom">Book Now</button>
                    <div id="paypal-button-container"></div>
                </div>
            </div>
        </article>
    </div>

    <div class="actions-row">
        <a href="/listings/<%= listing._id %>/edit" class="btn-secondary-custom">Edit Listing</a>
        <form class="d-inline" method="POST" action="/listings/<%= listing._id %>?_method=DELETE">
            <button class="btn-secondary-custom" type="submit">Delete Listing</button>
        </form>
    </div>

    <section class="review-section">
        <div class="review-form">
            <h4>Leave a review</h4>
            <form
                action="/listings/<%= listing.id %>/reviews"
                method="POST"
                novalidate
                class="needs-validation"
            >
                <div class="mb-3">
                    <label for="rating" class="form-label">Rating</label>
                    <fieldset class="starability-slot">
                        <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" checked aria-label="No rating." />
                        <input type="radio" id="first-rate1" name="review[rating]" value="1" />
                        <label for="first-rate1" title="Terrible">1 star</label>
                        <input type="radio" id="first-rate2" name="review[rating]" value="2" />
                        <label for="first-rate2" title="Not good">2 stars</label>
                        <input type="radio" id="first-rate3" name="review[rating]" value="3" />
                        <label for="first-rate3" title="Average">3 stars</label>
                        <input type="radio" id="first-rate4" name="review[rating]" value="4" />
                        <label for="first-rate4" title="Very good">4 stars</label>
                        <input type="radio" id="first-rate5" name="review[rating]" value="5" />
                        <label for="first-rate5" title="Amazing">5 stars</label>
                    </fieldset>
                </div>

                <div class="mb-3">
                    <label for="comment" class="form-label">Comments</label>
                    <textarea
                        name="review[comment]"
                        id="comment"
                        cols="10"
                        rows="3"
                        class="form-control"
                        required
                    ></textarea>
                </div>
                <button class="btn-primary-custom" type="submit">Submit Review</button>
            </form>
        </div>

        <% if(listing.reviews.length>0){ %>
            <div class="review-list mt-4">
                <h4>All Reviews</h4>
                <% for(review of listing.reviews){ %>
                    <div class="review-item">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <span class="fw-bold">Review</span>
                        </div>
                        <p class="starability-result" data-rating="<%= review.rating %>"></p>
                        <p class="mb-1"><%= review.comment %></p>
                        <form method="POST" action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE">
                            <button class="btn-secondary-custom" type="submit">Delete</button>
                        </form>
                    </div>
                <% } %>
            </div>
        <% } %>
    </section>

    <div class="map-card">
        <h4>Where you'll be staying</h4>
        <div id="map"></div>
    </div>
</div>

<div id="listing-data" data-price="<%= listing.price || 0 %>" data-offer="<%= listing.offer || 0 %>" data-map-token="<%= process.env.MAP_TOKEN || '' %>"></div>

<script>
    const listingDataEl = document.getElementById('listing-data');
    const listingData = {
        price: Number(listingDataEl.dataset.price || 0),
        offer: Number(listingDataEl.dataset.offer || 0)
    };
    const basePrice = listingData.price;
    const offerPercent = listingData.offer;
    const durationInput = document.getElementById('durationInput');
    const originalTotalEl = document.getElementById('originalTotal');
    const discountedTotalEl = document.getElementById('discountedTotal');
    const offerPercentEl = document.getElementById('offerPercent');
    const decreaseButton = document.getElementById('decreaseDuration');
    const increaseButton = document.getElementById('increaseDuration');
    const bookButton = document.getElementById('bookButton');

    const formatRupee = (value) => Math.round(value).toLocaleString('en-IN');

    const updateTotals = () => {
        let days = Number(durationInput.value) || 1;
        if (days < 1) days = 1;
        durationInput.value = days;
        const originalTotal = basePrice * days;
        const discountedTotal = Math.round(originalTotal * (1 - offerPercent / 100));
        originalTotalEl.textContent = formatRupee(originalTotal);
        discountedTotalEl.textContent = formatRupee(discountedTotal);
        offerPercentEl.textContent = offerPercent;
    };

    decreaseButton.addEventListener('click', () => {
        durationInput.value = Math.max(1, Number(durationInput.value) - 1);
        updateTotals();
    });
    increaseButton.addEventListener('click', () => {
        durationInput.value = Number(durationInput.value) + 1;
        updateTotals();
    });
    durationInput.addEventListener('input', () => updateTotals());
    bookButton.addEventListener('click', () => {
        const days = Number(durationInput.value) || 1;
        const total = Math.round(basePrice * days * (1 - offerPercent / 100));
        alert(`Booking for ${days} day(s)\nTotal payable: ₹${formatRupee(total)}`);
    });

    updateTotals();

    const mapToken = listingDataEl.dataset.mapToken || '';
    mapboxgl.accessToken = mapToken;
    const map = new mapboxgl.Map({
        container: 'map',
        center: [88.363892, 22.572645],
        zoom: 9
    });
</script>
<% const paypalClientId = process.env.PAYPAL_CLIENT_ID || ''; %>
<% if (!paypalClientId) { %>
    <div class="paypal-warning">PayPal is not configured. Set PAYPAL_CLIENT_ID and PAYPAL_CLIENT_SECRET.</div>
<% } else { %>
    <script src="https://www.paypal.com/sdk/js?client-id=<%= paypalClientId %>&currency=INR"></script>
    <script>
        function showPayPalError(msg){
            console.error(msg);
            alert(msg);
        }

        paypal.Buttons({
            createOrder: async function(data, actions) {
                const days = Number(durationInput.value) || 1;
                try {
                    const res = await fetch(`/listings/<%= listing._id %>/create-paypal-order`, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ days })
                    });
                    if (!res.ok) {
                        const err = await res.json().catch(()=>({ error: 'Unknown error' }));
                        throw new Error(err.error || 'Failed to create order');
                    }
                    const data = await res.json();
                    return data.id;
                } catch (err) {
                    showPayPalError('Create order failed: ' + err.message);
                    throw err;
                }
            },
            onApprove: async function(data, actions) {
                try {
                    const res = await fetch(`/listings/<%= listing._id %>/capture-paypal-order`, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ orderID: data.orderID })
                    });
                    if (!res.ok) {
                        const err = await res.json().catch(()=>({ error: 'Unknown capture error' }));
                        throw new Error(err.error || 'Capture failed');
                    }
                    const result = await res.json();
                    if (result.status === 'COMPLETED' || result.details?.status === 'COMPLETED') {
                        alert('Payment completed successfully');
                    } else {
                        alert('Payment processed: ' + JSON.stringify(result));
                    }
                } catch (err) {
                    showPayPalError('Capture failed: ' + err.message);
                }
            },
            onError: function(err){
                showPayPalError('PayPal error: ' + (err && err.message ? err.message : err));
            }
        }).render('#paypal-button-container');
    </script>
<% } %>

<script>
document.addEventListener('DOMContentLoaded', function(){
    const main = document.getElementById('mainPhoto');
    if(!main) return;
    document.querySelectorAll('.thumb-btn').forEach(btn=>{
        btn.addEventListener('click', ()=>{
            const src = btn.getAttribute('data-src');
            if(src){
                main.src = src;
            }
        });
    });
    const showAll = document.querySelector('.show-all');
    if(showAll){
        showAll.addEventListener('click', ()=>{
            // open the main photo in a new tab (simple gallery fallback)
            window.open(main.src, '_blank');
        });
    }
});
</script>