<% layout("/layouts/boilerplate") %>

<style>
.offer-badge {
    position: absolute;
    top: 16px;
    left: 16px;
    z-index: 10;
    padding: 0.5rem 0.85rem;
    border-radius: 0.35rem;
    background: rgba(220,53,69,0.95);
    color: #fff;
    font-weight: 700;
}
.duration-controls {
    display: flex;
    align-items: center;
    gap: 0.5rem;
}
.duration-controls button {
    min-width: 45px;
}
.booking-box {
    background: #f8f9fa;
    border-radius: 0.5rem;
}
</style>

<div>
    <div class="row mt-3">
        <div class="col-8 offset-2">
            <h3><%= listing.title %></h3>
        </div>
        <div class="card col-6 offset-3 show-card listing-card position-relative">
            <img 
                src="<%= listing.image.url %>" 
                class="card-img-top show_image" 
                alt="listing_image"
            />
            <div class="offer-badge">
                <% if (listing.offer && listing.offer > 0) { %>
                    <%= listing.offer %>% OFF
                <% } else { %>
                    No Offer
                <% } %>
            </div>
            <div class="card-body">
                <p class="card-text">Owned by <i><%= listing.owner.username %></i></p>
                <p class="card-text"><%= listing.description %></p>
                <p class="card-text"><strong>Per day:</strong> &#8377; <%= listing.price %></p>
                <p class="card-text"><strong>Location:</strong> <%= listing.location %>, <%= listing.country %></p>
                <div class="booking-box p-3 mt-3">
                    <h5>Book your stay</h5>
                    <div class="duration-controls mb-3">
                        <button id="decreaseDuration" class="btn btn-outline-dark btn-sm" type="button">-</button>
                        <div>
                            <label class="form-label mb-1">Duration (days)</label>
                            <input id="durationInput" type="number" min="1" class="form-control" style="width:110px;" value="<%= listing.duration %>" />
                        </div>
                        <button id="increaseDuration" class="btn btn-outline-dark btn-sm" type="button">+</button>
                    </div>
                    <p class="mb-2"><strong>Original total:</strong> &#8377; <span id="originalTotal"></span></p>
                    <p class="mb-2"><strong>Offer:</strong> <span id="offerPercent"><%= listing.offer || 0 %></span>%</p>
                    <p class="mb-2"><strong>Total after offer:</strong> &#8377; <span id="discountedTotal"></span></p>
                    <button id="bookButton" type="button" class="btn btn-dark">Book Now</button>
                </div>
            </div>
        </div>
        <br/>
    </div>


    <div class="btns mt-3 text-center">
        <a href="/listings/<%= listing._id %>/edit" class="btn btn-dark me-2">Edit</a>
        <form class="d-inline" method="POST" action="/listings/<%= listing._id %>?_method=DELETE">
            <button class="btn btn-dark">Delete</button>
        </form>
    </div>



    <div class="col-8 offset-3 mb-3">
        
        <h4>Leave a review</h4>
        <form 
            action="/listings/<%= listing.id %>/reviews" 
            method="POST"
            novalidate  
            class="needs-validation" 
            
        >
            
            <div class="mb-3 mt-3">
                <label for="rating" class="form-label">Rating</label>
            <fieldset class="starability-slot">
                <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" checked aria-label="No rating." />
                <input type="radio" id="first-rate1" name="review[rating]" value="1" />
                <label for="first-rate1" title="Terrible">1 star</label>
                <input type="radio" id="first-rate2" name="review[rating]" value="2" />
                <label for="first-rate2" title="Not good">2 stars</label>
                <input type="radio" id="first-rate3" name="review[rating]" value="3" />
                <label for="first-rate3" title="Average">3 stars</label>
                <input type="radio" id="first-rate4" name="review[rating]" value="4" />
                <label for="first-rate4" title="Very good">4 stars</label>
                <input type="radio" id="first-rate5" name="review[rating]" value="5" />
                <label for="first-rate5" title="Amazing">5 stars</label>
            </fieldset>
            </div>


            <div class="mb-3 mt-3">
                <label for="comment" class="form-label">Comments</label>
                <textarea 
                    name="review[comment]" 
                    id="comment" 
                    cols="10" 
                    rows="2" 
                    class="form-control" 
                    required
                ></textarea> 
            </div>
            <button class="btn btn-outline-dark">Submit</button>
        </form>
        <hr>
        <% if(listing.reviews.length>0){ %>
        <div class="row">
            <p><b>All Reviews</b></p>
            <%for(review of listing.reviews){%>
                <div class="card col-5 ms-3 mb-3">
                <div class="card-body">
                    <h5 class="card-title">demo0</h5>
                <p class="starability-result card-text" data-rating="<%= review.rating %>"></p>
                <p class="card-text"><%= review.comment %></p>

            </div>
            <form class="mb-3" method="POST" action="/listings/<%=listing._id %>/reviews/<%=review._id %>?_method=DELETE">
                <button class="btn btn-sm btn-dark">Delete</button>
            </form>
        </div>
        <% } %>
        </div>
        <%} %>
    </div>
    <div class="col-8 offset-3 mb-3">
            <h3>Where you'll be staying</h3>
            <div id="map"></div>
    </div>
</div> 

<div id="listing-data" data-price="<%= listing.price || 0 %>" data-offer="<%= listing.offer || 0 %>" data-map-token="<%= process.env.MAP_TOKEN || '' %>" style="display:none;"></div>

<script>
    const listingDataEl = document.getElementById('listing-data');
    const listingData = {
        price: Number(listingDataEl.dataset.price || 0),
        offer: Number(listingDataEl.dataset.offer || 0)
    };
    const basePrice = listingData.price;
    const offerPercent = listingData.offer;
    const durationInput = document.getElementById('durationInput');
    const originalTotalEl = document.getElementById('originalTotal');
    const discountedTotalEl = document.getElementById('discountedTotal');
    const offerPercentEl = document.getElementById('offerPercent');
    const decreaseButton = document.getElementById('decreaseDuration');
    const increaseButton = document.getElementById('increaseDuration');
    const bookButton = document.getElementById('bookButton');

    const formatRupee = (value) => Math.round(value).toLocaleString('en-IN');

    const updateTotals = () => {
        let days = Number(durationInput.value) || 1;
        if (days < 1) days = 1;
        durationInput.value = days;
        const originalTotal = basePrice * days;
        const discountedTotal = Math.round(originalTotal * (1 - offerPercent / 100));
        originalTotalEl.textContent = formatRupee(originalTotal);
        discountedTotalEl.textContent = formatRupee(discountedTotal);
        offerPercentEl.textContent = offerPercent;
    };

    decreaseButton.addEventListener('click', () => {
        durationInput.value = Math.max(1, Number(durationInput.value) - 1);
        updateTotals();
    });
    increaseButton.addEventListener('click', () => {
        durationInput.value = Number(durationInput.value) + 1;
        updateTotals();
    });
    durationInput.addEventListener('input', () => updateTotals());
    bookButton.addEventListener('click', () => {
        const days = Number(durationInput.value) || 1;
        const total = Math.round(basePrice * days * (1 - offerPercent / 100));
        alert(`Booking for ${days} day(s)\nTotal payable: ₹${formatRupee(total)}`);
    });

    updateTotals();

    const mapToken = listingDataEl.dataset.mapToken || '';
    mapboxgl.accessToken = mapToken;
    const map = new mapboxgl.Map({
        container: 'map',
        center: [88.363892, 22.572645],
        zoom: 9
    });
</script>